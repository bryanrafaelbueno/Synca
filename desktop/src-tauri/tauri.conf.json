{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synca",
  "version": "0.3.0",
  "identifier": "io.synca.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Synca",
        "width": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "publisher": "Bryan Rafael <brthy467@gmail.com>",
    "category": "Utility",
    "shortDescription": "Lightweight Linux file sync client",
    "longDescription": "Synca keeps local folders in sync with cloud storage through a lightweight daemon and native desktop UI.",
    "targets": [
      "deb",
      "appimage",
      "nsis"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "packaging/hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "postInstallScript": "packaging/postinst",
        "postRemoveScript": "packaging/postrm",
        "files": {
          "/usr/lib/systemd/user/synca.service": "packaging/synca.service",
          "/usr/lib/systemd/user-preset/99-synca.preset": "packaging/99-synca.preset"
        }
      }
    },
    "externalBin": [
      "../../bin/synca-daemon"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/StoreLogo.png",
      "icons/Square30x30Logo.png",
      "icons/Square44x44Logo.png",
      "icons/Square71x71Logo.png",
      "icons/Square89x89Logo.png",
      "icons/Square107x107Logo.png",
      "icons/Square142x142Logo.png",
      "icons/Square150x150Logo.png",
      "icons/Square284x284Logo.png",
      "icons/Square310x310Logo.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}